    "default_print_language": "en",
    "disabled": 0,
    "doc_type": "B2B Pick Report",
    "doctype": "Print Format",
    "font": "Default",
    "html": "<style>\n  body { font-family: system-ui, sans-serif; color: #333; }\n  h1 { margin: 0 0 4px; font-size: 18px; }\n  h3 { margin: 20px 0 8px; font-size: 13px; text-transform: uppercase; color: #555; }\n  .meta { color: #666; font-size: 12px; margin: 0 0 4px; }\n  .badge { display: inline-block; padding: 3px 10px; border-radius: 6px; font-size: 11px; font-weight: bold; margin-right: 6px; }\n  .badge-mr  { background: #fef3c7; color: #92400e; }\n  .badge-se  { background: #d1fae5; color: #065f46; }\n  .badge-partial { background: #fde8d8; color: #9a3412; }\n  .badge-full    { background: #d1fae5; color: #065f46; }\n  .printed { color: #999; font-size: 11px; margin: 0 0 16px; }\n  table { border-collapse: collapse; width: 100%; margin-bottom: 16px; }\n  th { background: #f3f4f6; text-align: left; padding: 7px 10px; border: 1px solid #ddd; font-size: 11px; text-transform: uppercase; }\n  td { padding: 6px 10px; border: 1px solid #ddd; font-size: 12px; }\n  .num { text-align: right; }\n  .over { color: #dc2626; font-weight: bold; }\n  .ok   { color: #16a34a; font-weight: bold; }\n  .dim  { color: #888; font-size: 11px; }\n  .divider { border: none; border-top: 1px dashed #ddd; margin: 20px 0; }\n</style>\n\n<h1>B2B Order Pick &mdash; Completion Summary</h1>\n\n<p class=\"meta\">\n  <strong>Sales Order:</strong> {{ doc.sales_order or \"&mdash;\" }}\n  &nbsp;&nbsp;\n  <strong>Customer:</strong> {{ doc.customer_name or \"&mdash;\" }}\n</p>\n\n<p class=\"meta\">\n  <span class=\"badge badge-mr\">MR: {{ doc.material_request or \"&mdash;\" }}</span>\n  <span class=\"badge badge-se\">SE: {{ doc.stock_entry or \"&mdash;\" }}</span>\n  {% if doc.is_partial %}\n  <span class=\"badge badge-partial\">Partial Pick</span>\n  {% else %}\n  <span class=\"badge badge-full\">Fully Picked</span>\n  {% endif %}\n</p>\n\n<p class=\"meta\"><strong>Picked By:</strong> {{ doc.picked_by or \"&mdash;\" }}</p>\n<p class=\"meta\"><strong>Pick Date:</strong> {{ doc.pick_date or \"&mdash;\" }}</p>\n<p class=\"printed\">Printed: {{ frappe.format(frappe.utils.now(), {\"fieldtype\": \"Datetime\"}) }}</p>\n\n<hr class=\"divider\">\n\n<h3>Transfer Items</h3>\n<table>\n  <thead>\n    <tr>\n      <th>#</th>\n      <th>Item Code</th>\n      <th>Item Name</th>\n      <th class=\"num\">Order Qty</th>\n      <th class=\"num\">Picked Qty</th>\n      <th>UOM</th>\n      <th>Source Warehouse</th>\n      <th>Dest Warehouse</th>\n    </tr>\n  </thead>\n  <tbody>\n    {% for item in doc.items %}\n    {% set over = item.picked_qty > item.order_qty and item.order_qty > 0 %}\n    <tr>\n      <td class=\"dim\">{{ loop.index }}</td>\n      <td><strong>{{ item.item_code }}</strong></td>\n      <td>{{ item.item_name or \"\" }}</td>\n      <td class=\"num\">{{ item.order_qty }}</td>\n      <td class=\"num {% if over %}over{% else %}ok{% endif %}\">\n        {{ item.picked_qty }}{% if over %} &#9888;{% endif %}\n      </td>\n      <td>{{ item.uom or \"Nos\" }}</td>\n      <td class=\"dim\">{{ item.source_warehouse or \"\" }}</td>\n      <td class=\"dim\">{{ item.target_warehouse or \"\" }}</td>\n    </tr>\n    {% endfor %}\n  </tbody>\n</table>",
    "line_breaks": 0,
    "modified": "2026-04-05 00:00:01.000000",
    "modified_by": "Administrator",
    "module": "Order Picking",
    "name": "B2B Pick Report Summary",
    "owner": "Administrator",
    "print_format_builder": 0,
    "print_format_type": "Jinja",
    "show_section_headings": 0,
    "standard": "Yes"
}
