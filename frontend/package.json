{
    "name": "order-picking-frontend",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "node node_modules/vite/bin/vite.js build --base=/assets/order_picking/frontend/ && npm run copy-html-entry",
        "preview": "node node_modules/vite/bin/vite.js preview",
        "copy-html-entry": "node -e \"require('fs').copyFileSync('../order_picking/public/frontend/index.html', '../order_picking/www/order_picking.html')\""
    },
    "dependencies": {
        "vue": "^3.4.21"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.4",
        "autoprefixer": "^10.4.19",
        "postcss": "^8.4.38",
        "tailwindcss": "^3.4.3",
        "vite": "^5.2.0"
    }
}